-- ================= HELPER FUNCTIONS =================

-- Reliable teleport using PivotTo + zero velocity
local function teleportTo(targetCFrame)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    char:PivotTo(targetCFrame)
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
end

-- Get CFrame from any instance (BasePart or Model)
local function getCFrame(obj)
    if not obj then return CFrame.new() end
    if obj:IsA("BasePart") then
        return obj.CFrame
    elseif obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.CFrame
        end
        local part = obj:FindFirstChildWhichIsA("BasePart", true)
        if part then return part.CFrame end
        return obj:GetPivot()
    end
    return CFrame.new()
end

-- Find this player's owned plot by scanning all known attribute names + name fallback
local function findOwnerPlot()
    local ok, plots = pcall(function() return workspace.Plots:GetChildren() end)
    if not ok or not plots then return nil end
    local idStr = tostring(player.UserId)
    local attrVariants = { "OwnerUserID", "OwnerUserId", "OwnerId", "OwnerID", "UserId", "UserID" }
    for _, plot in ipairs(plots) do
        for _, attrName in ipairs(attrVariants) do
            local ok2, val = pcall(function() return plot:GetAttribute(attrName) end)
            if ok2 and val and tostring(val) == idStr then
                return plot
            end
        end
        -- Fallback: match by name attribute
        local ok3, nameAttr = pcall(function()
            return plot:GetAttribute("OwnerName") or plot:GetAttribute("Owner")
        end)
        if ok3 and nameAttr and tostring(nameAttr) == playerUsername then
            return plot
        end
    end
    return nil
end

-- Check if a value is in a selection (handles both table from Multi and plain string)
local function isSelected(value, selection)
    if type(selection) == "table" then
        for _, v in ipairs(selection) do
            if v == value then return true end
        end
        return false
    end
    return tostring(selection) == tostring(value)
end

local function selectionIsEmpty(selection)
    if type(selection) == "table" then
        return next(selection) == nil
    end
    return selection == nil or tostring(selection) == ""
end

-- Shared logic used by Auto Get Brainrot and Auto Dupe.
local function tryCollectBrainrotByRarity(raritySelection)
    local activeFolder = workspace:FindFirstChild("ActiveBrainrots")
    if not activeFolder then return false, nil, nil, nil end

    for _, hitbox in ipairs(activeFolder:GetChildren()) do
        local rarityAttr = hitbox:GetAttribute("Rarity")
        local spawnCF = hitbox:GetAttribute("SpawnCFrame")
        local rarityMatch = selectionIsEmpty(raritySelection) or isSelected(rarityAttr, raritySelection)

        if rarityMatch then
            local targetCF = spawnCF or getCFrame(hitbox)
            teleportTo(targetCF + Vector3.new(0, 5, 0))
            task.wait(0.3)
            teleportTo(targetCF + Vector3.new(0, 3, 0))
            task.wait(0.4)

            local prompt = hitbox:FindFirstChildOfClass("ProximityPrompt", true)
            if not prompt then
                local attachment = hitbox:FindFirstChild("Attachment")
                if attachment then
                    prompt = attachment:FindFirstChildOfClass("ProximityPrompt")
                end
            end

            if prompt then
                fireproximityprompt(prompt)
                return true, hitbox, targetCF, prompt
            end
        end
    end

    return false, nil, nil, nil
end

