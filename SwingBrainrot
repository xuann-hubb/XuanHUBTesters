-- ================= key system =================
local BaseURL = "https://new.pandadevelopment.net/api/v1"
local Client_ServiceID = "xuanketsyste" -- <- Change this to your service ID

WindUI.Services.newpandadevelopment = {
    Name = "New Panda Development",
    Icon = "key",
    Args = { "ServiceID" },

    New = function(ServiceID)
        -- Use ServiceID if provided
        local ServiceIDToUse = ServiceID or Client_ServiceID

        -- Get Hardware ID
        local function getHardwareId()
            local success, hwid = pcall(gethwid)
            if success and hwid then return hwid end

            local RbxAnalyticsService = game:GetService("RbxAnalyticsService")
            local clientId = tostring(RbxAnalyticsService:GetClientId())
            return clientId:gsub("-", "")
        end

        -- HTTP POST Request wrapper
        local function makeRequest(endpoint, body)
            local url = BaseURL .. endpoint
            local jsonBody = HttpService:JSONEncode(body)

            local response = request({
                Url = url,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = jsonBody
            })

            if response and response.Body then
                return HttpService:JSONDecode(response.Body)
            end

            return nil
        end

        -- Validate a key
        local function validateKey(key, Premium_Verification)
            if not key or key == "" then return false, "Invalid key" end

            local hwid = getHardwareId()
            local result = makeRequest("/keys/validate", {
                ServiceID = ServiceIDToUse,
                HWID = hwid,
                Key = key
            })

            if not result then
                return false, "Failed to connect to server"
            end

            local isAuthenticated = result.Authenticated_Status == "Success"
            local isPremium = result.Key_Premium or false
            local isValid = isAuthenticated
            local message = result.Note or (isAuthenticated and "Key validated!" or "Invalid key")

            if Premium_Verification and isAuthenticated and not isPremium then
                isValid = false
                message = "Premium key required"
            end

            return isValid, message, isPremium, result.Expire_Date
        end

        -- Get Key URL
        local function getKeyURL()
            local hwid = getHardwareId()
            return "https://new.pandadevelopment.net/getkey/" .. ServiceIDToUse .. "?hwid=" .. hwid
        end

        -- Copy Key URL to clipboard
        local function copyLink()
            local url = getKeyURL()
            if setclipboard then
                setclipboard(url)
                print("Key URL copied to clipboard: " .. url)
            end
            return url
        end

        return {
            Verify = validateKey,
            Copy = copyLink,
            GetLink = getKeyURL
        }
    end
}


