MainSection:Button({
    Title = "Find Best Income",
    Icon = "solar:chart-bold",
    Desc = "Finds the brainrot with the best income on the map",
    Callback = function()
        local brainrots = game:GetService("Workspace").ActiveBrainrots:GetChildren()
        local best = nil
        local bestIncome = 0
        for _, br in ipairs(brainrots) do
            local income = br:FindFirstChild("Income") or br:FindFirstChild("Cash") or br:FindFirstChild("Money")
            local val = income and income.Value or 0
            if val > bestIncome then
